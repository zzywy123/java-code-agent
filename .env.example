# LLM Provider: deepseek | openai | ollama
PROVIDER=deepseek

# Provider credentials. Never commit real keys.
DEEPSEEK_API_KEY=your-deepseek-api-key
OPENAI_API_KEY=your-openai-api-key

# Optional provider overrides
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5-coder:7b

# Agent settings
AGENT_MAX_ITERATIONS=15
AGENT_MAX_CONSECUTIVE_FAILURES=3
TEMPERATURE=0.0
MAX_TOKENS=4096

# Security
AGENT_REQUIRE_APPROVAL=true
AGENT_COMMAND_TIMEOUT=120
AGENT_MAX_OUTPUT_CHARS=50000
AGENT_REPO_ROOT=./demo-repo

# RAG index lifecycle
# Set false when Hugging Face is unavailable; BM25 remains available.
RAG_ENABLE_VECTOR=true
RAG_INDEX_DIR=.agent-index
RAG_FORCE_REINDEX=false
RAG_VECTOR_TOP_K=20
RAG_BM25_TOP_K=20
RAG_FUSION_TOP_K=15
RAG_RERANK_ENABLED=false
RAG_MAX_RETRIEVAL_ROUNDS=3
RAG_EVIDENCE_THRESHOLD=0.6

# Embedding (only used when RAG_ENABLE_VECTOR=true)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
EMBEDDING_BATCH_SIZE=32

# Memory and MCP
MEMORY_CHECKPOINT_DIR=.checkpoints
MEMORY_LONG_TERM_PERSIST_DIR=.memory
MEMORY_SHORT_TERM_WINDOW=20
MEMORY_SUMMARY_TRIGGER=30
MCP_ENABLED=true
MCP_TRANSPORT=stdio
WORKFLOW_MAX_REWORK=2

# Observability. Cost rates are optional and intentionally not hardcoded.
OBSERVABILITY_ENABLED=true
OBSERVABILITY_TRACE_DIR=.observability/traces
# OBSERVABILITY_INPUT_COST_PER_MILLION=0.0
# OBSERVABILITY_OUTPUT_COST_PER_MILLION=0.0
